# Morrow Lab — Required Environment Variables
# Copy this to .env and fill in real values

# AI APIs
REPLICATE_TOKEN=r8_your_token_here
HOMEDESIGNS_TOKEN=your_jwt_token_here
GROQ_API_KEY=gsk_your_key_here

# Email
RESEND_KEY=re_your_key_here

# Auth
JWT_SECRET=generate-a-strong-random-secret-here

# Server (for deploy scripts only)
SSH_HOST=your.server.ip
SSH_USER=root

# n8n
N8N_API_KEY=your_n8n_api_key_here

# GitHub (for CI/CD)
GITHUB_TOKEN=github_pat_your_token_here

# SMM (Postmypost)
POSTMYPOST_API_KEY=aka_your_key_here
POSTMYPOST_PROJECT_ID=
