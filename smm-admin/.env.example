# ============================================================
# smm-admin — переменные окружения
# Скопируй в .env.local и заполни значения
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/smm_admin

# JWT secret for auth tokens (generate a random 64+ char string)
JWT_SECRET=change_me_to_random_secret

# Groq API key for AI generation (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Resend API key for transactional emails (https://resend.com)
RESEND_API_KEY=re_...

# n8n (webhook для AI-генерации)
N8N_BASE_URL=https://n8n.zenohome.by
N8N_WEBHOOK_SECRET=change_me_to_random_secret

# App
NEXT_PUBLIC_APP_URL=https://smm.morrowlab.by
